# ── Local vs Cloud ──────────────────────────────────────────────────────────
LOCAL_DEV=true

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=your-db-user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=platform
DATABASE_URL=postgresql+asyncpg://your-db-user:change-me@localhost:5432/platform

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── API Security ─────────────────────────────────────────────────────────────
API_KEY=dev-key

# ── AWS (required when LOCAL_DEV=false) ──────────────────────────────────────
AWS_REGION=eu-central-1
AWS_ACCOUNT_ID=123456789012
STACK_NAME=health-platform-poc

# ── AWS IoT Core ─────────────────────────────────────────────────────────────
AWS_IOT_ENDPOINT=a18w2lxry9lfxy-ats.iot.eu-central-1.amazonaws.com
AWS_IOT_POLICY_NAME=HealthPlatformDevicePolicy
AWS_IOT_THING_TYPE=HealthPlatformDevice

# ── Kinesis ──────────────────────────────────────────────────────────────────
KINESIS_STREAM_NAME=health-platform-events
KINESIS_SHARD_COUNT=2

# ── IoT CA Certificates (required for bootstrap.sh) ──────────────────────────
CA_CERT_FILE=infra/certs/root-ca.pem
CA_KEY_FILE=infra/certs/root-ca.key

# ── Recommendation Providers ─────────────────────────────────────────────────
SERVICE1_ENDPOINT=https://a2da22tugdqsame4ckd3oohkmu0tnbne.lambda-url.eu-central-1.on.aws/services/service1
SERVICE1_TOKEN=service1-dev

SERVICE2_ENDPOINT=https://a2da22tugdqsame4ckd3oohkmu0tnbne.lambda-url.eu-central-1.on.aws/services/service2

SERVICE3_ENDPOINT=
SERVICE3_API_TOKEN=
# service1_schema or service2_schema
SERVICE3_SCHEMA=service1_schema

# ── Recommendation Aggregation ────────────────────────────────────────────────
RECOMMENDATION_TIMEOUT_SECONDS=0.8
MIN_RECOMMENDATION_SCORE=200.0

# ── Telemetry & Staleness ────────────────────────────────────────────────────
STALENESS_THRESHOLD_HOURS=24

# ── MQTT (local dev) ─────────────────────────────────────────────────────────
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_TOPIC_PREFIX=health/telemetry

# ── OpenTelemetry ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=health-platform

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Seeding ──────────────────────────────────────────────────────────────────
SEED_DEVICE_COUNT=10

# ── ML Training ──────────────────────────────────────────────────────────────
# Minimum distinct calendar days of telemetry a device must have to be included
# in model training. Set to 1 for PoC/dev; increase (e.g. 7) for production.
MIN_TELEMETRY_DAYS=1

# ── Grafana ───────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=change-me
