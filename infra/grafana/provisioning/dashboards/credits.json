{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Credits & Rewards Dashboard — balances, earning/spending, tiers, streaks",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": {} },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "sortBy": [{ "displayName": "Value", "desc": true }]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "device_credit_balance",
          "legendFormat": "{{device_id}}",
          "refId": "A"
        }
      ],
      "title": "Credits Balance by Device",
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(device_credits_earned_total[5m])) by (device_id)",
          "legendFormat": "Earned — {{device_id}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(device_credits_spent_total[5m])) by (device_id)",
          "legendFormat": "Spent — {{device_id}}",
          "refId": "B"
        }
      ],
      "title": "Credits Earned vs Spent over Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "id": 3,
      "options": { "pieType": "pie", "legend": { "displayMode": "list" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "credit_tier_total",
          "legendFormat": "{{tier}}",
          "refId": "A"
        }
      ],
      "title": "Tier Distribution",
      "type": "piechart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "id": 4,
      "options": {
        "sortBy": [{ "displayName": "Value", "desc": true }],
        "footer": {}
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(10, increase(device_credits_spent_total[24h]))",
          "legendFormat": "{{device_id}}",
          "refId": "A"
        }
      ],
      "title": "Top Credit Spenders (last 24h)",
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "id": 5,
      "options": {
        "sortBy": [{ "displayName": "Value", "desc": true }]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(10, device_streak_days)",
          "legendFormat": "{{device_id}}",
          "refId": "A"
        }
      ],
      "title": "Streak Leaderboard (top 10)",
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": {} }, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 6,
      "options": { "xField": "action_type" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(device_credits_earned_total[24h])) by (action_type)",
          "legendFormat": "{{action_type}}",
          "refId": "A"
        }
      ],
      "title": "Activity Type Breakdown (last 24h)",
      "type": "barchart"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["credits", "rewards"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Credits & Rewards",
  "uid": "credits-rewards-001",
  "version": 1
}
