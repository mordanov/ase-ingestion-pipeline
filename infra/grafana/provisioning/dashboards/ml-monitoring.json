{
  "title": "ML Monitoring — Recommendations",
  "uid": "ml-monitoring",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [

    {
      "id": 1,
      "title": "Re-ranker NDCG@10",
      "description": "Normalised Discounted Cumulative Gain at rank 10 from the most recent training evaluation. Higher is better (max 1.0).",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "percentunit",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.7 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "ml_reranker_ndcg_at_10",
          "legendFormat": "NDCG@10"
        }
      ]
    },

    {
      "id": 2,
      "title": "Anomaly Detector F1 Score",
      "description": "F1 score of the anomaly detector from the most recent training evaluation. Higher is better (max 1.0).",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "percentunit",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.7 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "ml_anomaly_detector_f1_score",
          "legendFormat": "F1"
        }
      ]
    },

    {
      "id": 3,
      "title": "ML Inference P99 Latency (ms)",
      "description": "Rolling 300-second p99 inference latency for the re-ranking step. Alert threshold: 200 ms.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "ml_inference_p99_latency_ms",
          "legendFormat": "p99 latency"
        }
      ]
    },

    {
      "id": 4,
      "title": "Model Staleness (seconds since last training)",
      "description": "Seconds elapsed since the last successful model training run. A value above 86400 (24 h) may indicate the retraining schedule has stopped.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 43200 },
              { "color": "red", "value": 86400 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "ml_model_staleness_seconds",
          "legendFormat": "staleness"
        }
      ]
    },

    {
      "id": 5,
      "title": "Recommendation Request Volume by ML Path",
      "description": "Requests per minute split by ML path: scored (warm user with embedding), cold_start (< 7 days history or cache miss), fallback (ML layer unavailable).",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ml_inference_outcome_total{outcome=\"scored\"}[1m]) * 60",
          "legendFormat": "scored"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ml_inference_outcome_total{outcome=\"cold_start\"}[1m]) * 60",
          "legendFormat": "cold-start"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ml_inference_outcome_total{outcome=\"fallback\"}[1m]) * 60",
          "legendFormat": "fallback"
        }
      ]
    },

    {
      "id": 6,
      "title": "Anomaly Suppression Rate",
      "description": "Items suppressed per minute (anomaly_suppressed=true) relative to total recommendation items evaluated with an active baseline.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "red", "value": 0.6 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ml_anomaly_suppressed_items_total[5m]) / clamp_min(rate(ml_anomaly_requests_evaluated_total[5m]), 0.001)",
          "legendFormat": "suppression rate"
        }
      ]
    },

    {
      "id": 7,
      "title": "NDCG@10",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.7 }
            ]
          },
          "mappings": [
            { "type": "special", "options": { "match": "null", "result": { "text": "No model" } } }
          ]
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "ml_reranker_ndcg_at_10",
          "legendFormat": "NDCG@10"
        }
      ]
    },

    {
      "id": 8,
      "title": "Anomaly F1",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.7 }
            ]
          },
          "mappings": [
            { "type": "special", "options": { "match": "null", "result": { "text": "No model" } } }
          ]
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "ml_anomaly_detector_f1_score",
          "legendFormat": "F1"
        }
      ]
    },

    {
      "id": 9,
      "title": "P99 Latency",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 200 }
            ]
          },
          "mappings": [
            { "type": "special", "options": { "match": "null", "result": { "text": "No data" } } }
          ]
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "ml_inference_p99_latency_ms",
          "legendFormat": "p99"
        }
      ]
    },

    {
      "id": 10,
      "title": "Model Staleness",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 43200 },
              { "color": "red", "value": 86400 }
            ]
          },
          "mappings": [
            { "type": "special", "options": { "match": "null", "result": { "text": "Never trained" } } }
          ]
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "ml_model_staleness_seconds",
          "legendFormat": "staleness"
        }
      ]
    }

  ]
}
